# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # Required for backend writes

# Backend API Configuration (for webapp directory)
SECRET_KEY=your_secret_key_here_min_32_chars
DATABASE_URL=postgresql://user:password@localhost/dealerscope
REDIS_URL=redis://localhost:6379

# Application Settings
ENVIRONMENT=development
DEBUG=true
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload
MAX_FILE_SIZE=50000000
ALLOWED_FILE_TYPES=text/csv,application/vnd.ms-excel

# External APIs (optional)
OPENAI_API_KEY=your_openai_key_here
MANHEIM_API_KEY=your_manheim_key_here
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Apify Integration
APIFY_API_TOKEN=your_apify_token_here
APIFY_WEBHOOK_SECRET=replace_with_32_plus_random_chars
APIFY_WEBHOOK_SECRET_PREVIOUS=

# Rover / Frontend API
VITE_API_URL=http://localhost:8000
