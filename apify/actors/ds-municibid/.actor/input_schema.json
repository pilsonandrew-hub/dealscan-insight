{
  "title": "DealerScope Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQuery": {
      "title": "Search Query",
      "type": "string",
      "description": "Keyword search (e.g. 'Tesla'). Appended as ?q= to category URLs and post-filtered on title.",
      "default": "",
      "editor": "textfield"
    },
    "maxPages": {
      "title": "Max Pages",
      "type": "integer",
      "description": "Maximum pages to crawl",
      "default": 15,
      "minimum": 1,
      "maximum": 100,
      "editor": "number"
    },
    "minBid": {
      "title": "Minimum Bid ($)",
      "type": "integer",
      "description": "Minimum current bid",
      "default": 1000,
      "minimum": 0,
      "editor": "number"
    },
    "maxMileage": {
      "title": "Maximum Mileage",
      "type": "integer",
      "description": "Max odometer for the DealerScope standard lane (miles)",
      "default": 100000,
      "minimum": 0,
      "editor": "number"
    },
    "minYear": {
      "title": "Minimum Model Year",
      "type": "integer",
      "description": "Oldest standard-lane model year to include",
      "default": 2016,
      "minimum": 1990,
      "editor": "number"
    },
    "targetStates": {
      "title": "Target States",
      "type": "array",
      "description": "Low-rust states to include",
      "default": ["AZ","CA","NV","CO","NM","UT","TX","FL","GA","SC","TN","NC","VA","WA","OR","HI"],
      "editor": "stringList",
      "items": { "type": "string" }
    }
  }
}
