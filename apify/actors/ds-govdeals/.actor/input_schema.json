{
  "title": "GovDeals Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "maxPages": {
      "title": "Max Pages",
      "type": "integer",
      "description": "Max pages to scrape",
      "default": 10,
      "minimum": 1,
      "maximum": 100
    },
    "minBid": {
      "title": "Minimum Bid",
      "type": "integer",
      "description": "Minimum current bid in USD",
      "default": 500,
      "minimum": 0
    },
    "maxBid": {
      "title": "Maximum Bid",
      "type": "integer",
      "description": "Maximum current bid in USD",
      "default": 75000,
      "minimum": 0
    },
    "targetStates": {
      "title": "Target States",
      "type": "array",
      "description": "Low rust states to target",
      "default": ["AZ","CA","NV","CO","NM","UT","TX","FL","GA","SC","TN","NC","VA","WA","OR","HI"],
      "editor": "stringList",
      "items": { "type": "string" }
    },
    "vehicleCategories": {
      "title": "Vehicle Categories",
      "type": "array",
      "description": "Categories to scrape",
      "default": ["Automobiles & Trucks"],
      "editor": "stringList",
      "items": { "type": "string" }
    }
  }
}
