{
  "version": 1,
  "enforcement_mode": "audit",
  "closeout": {
    "block_on_governed_dirty": true,
    "block_on_missing_next_start": true,
    "block_on_pending_replication": true,
    "block_on_unsatisfied_recall": true
  },
  "recall": {
    "post_gap_requires_recall": true,
    "post_compaction_requires_recall": true,
    "exact_claim_requires_recall": true,
    "closure_claim_requires_recall_if_prior_context_dependency": true
  },
  "mirror": {
    "named_paths": [
      "03_Operations/DealerScope-Active-Work-Queue.md",
      "03_Operations/DealerScope-Governed-Closure-Board.md"
    ]
  },
  "briefing": {
    "daily_briefing_glob": "DealerScope-Morning-Briefing-*.md",
    "cto_note_glob": "*CTO*.md",
    "daily_briefing_root": "brains/dealerscope-brain/03_Operations",
    "projection_artifact": true,
    "tracked_canonical": false,
    "freshness_max_hours": 18,
    "require_today_file": true,
    "require_mirror_projection": true,
    "ignore_protocol_and_template": true
  },
  "artifact_families": {
    "governed_source": {
      "classification": "canonical_tracked_truth",
      "roots": [
        "brains/dealerscope-brain/00_Start-Here",
        "brains/dealerscope-brain/01_Standards",
        "brains/dealerscope-brain/02_Architecture",
        "brains/dealerscope-brain/03_Operations",
        "brains/dealerscope-brain/05_Incidents",
        "brains/dealerscope-brain/06_Integrations",
        "brains/dealerscope-brain/90_Templates",
        "brains/dealerscope-brain/people",
        "brains/dealerscope-brain/companies",
        "brains/dealerscope-brain/concepts",
        "brains/dealerscope-brain/deals",
        "brains/dealerscope-brain/meetings",
        "brains/dealerscope-brain/operations",
        "brains/dealerscope-brain/projects",
        "brains/dealerscope-brain/systems",
        "brains/dealerscope-brain/sources",
        "brains/dealerscope-brain/originals"
      ]
    },
    "mirror_projection": {
      "classification": "operator_visible_projection",
      "roots": [
        "/Users/andrewpilson/Documents/Obsidian Vault/DealerScope Brain"
      ]
    },
    "local_archive": {
      "classification": "workspace_local_archive_not_governed_truth",
      "roots": [
        "reports"
      ]
    },
    "ignored_runtime": {
      "classification": "generated_runtime_state_not_governed_truth",
      "roots": [
        "continuity/continuity-state.json",
        "continuity/closeout-evaluation.json",
        "continuity/continuity-events.jsonl",
        "continuity/continuity-metrics.json",
        "brains/dealerscope-brain/03_Operations/DealerScope-Morning-Briefing-20*.md"
      ]
    }
  },
  "workspace_boundary": {
    "tracked_by_continuity_loop": [
      "brains/dealerscope-brain",
      "continuity/policy.json",
      "continuity/open-loops.json",
      "continuity/pending-promotions.json",
      "scripts/dealerscope-continuity-status.py",
      "scripts/manage-continuity-promotion-queue.py",
      "scripts/generate-dealerscope-daily-briefing.py",
      "scripts/continuity-closeout-check.sh"
    ],
    "explicitly_out_of_scope_local_surfaces": [
      "MEMORY.md",
      "SOUL.md",
      "NORTH_STAR.md",
      "memory/*.md"
    ],
    "interpretation": "personal_workspace_surfaces_do_not_count_as_continuity_loop_dirt"
  },
  "promotion": {
    "queue_path": "continuity/pending-promotions.json",
    "require_queue_file": true,
    "max_advisory_item_age_hours": 24,
    "surface_in_briefing": true,
    "open_loop_promote_flag": true,
    "closeout_blocking_creates_candidate": true,
    "malformed_open_loops_create_candidate": true,
    "execution_model": "single_supported_destination_only",
    "architecture_decision": "final_intended_scope_currently_single_execution_destination",
    "system_grade_classification": {
      "broad_enterprise_system_claim": "fail",
      "narrow_explicitly_scoped_architecture": "pass"
    },
    "execution_scope_decision": "non_work_queue_destinations_remain_verification_only_by_design_until_explicitly_reapproved",
    "scope_interpretation": "verification_only_destinations_are_manual_by_default_not_automation_backlog",
    "execution_complete_destinations": [
      "work_queue"
    ],
    "verification_only_destinations": [
      "closure_board",
      "report",
      "doctrine",
      "policy"
    ],
    "verify_destinations": true,
    "destinations": {
      "work_queue": {
        "path": "brains/dealerscope-brain/03_Operations/DealerScope-Active-Work-Queue.md",
        "match_prefix": "### ",
        "execution": {
          "enabled": true,
          "allowed_target_statuses": [
            "queued",
            "ready",
            "in_progress",
            "blocked",
            "parked",
            "ready_for_review"
          ],
          "allowed_new_statuses": [
            "ready_for_review",
            "closed"
          ],
          "require_resolution_note": true,
          "append_promotion_evidence": true,
          "set_next_action_from_resolution": true,
          "require_fulfillment_proof": true,
          "require_pre_post_evidence": true,
          "require_target_status_echo": true
        }
      },
      "closure_board": {
        "path": "brains/dealerscope-brain/03_Operations/DealerScope-Governed-Closure-Board.md",
        "match_prefix": "### ",
        "classification": "proposed_execution_contract_pending_real_close_case_proof",
        "execution": {
          "enabled": true,
          "allowed_target_statuses": [
            "in_progress",
            "blocked"
          ],
          "allowed_new_statuses": [
            "closed"
          ],
          "require_resolution_note": true,
          "require_fulfillment_proof": true,
          "require_pre_post_evidence": true,
          "require_target_status_echo": true,
          "require_evidence_link": true,
          "require_closure_condition_match": true,
          "forbid_closure_condition_mutation": true,
          "forbid_schema_mutation": true,
          "forbid_unrelated_item_mutation": true,
          "bounded_mutation_fields": [
            "Current status",
            "Evidence link",
            "Next action"
          ]
        }
      },
      "report": {
        "path_prefix": "brains/dealerscope-brain/reports/",
        "require_file": true,
        "classification": "verification_only_by_default_local_archive_boundary",
        "execution": {
          "enabled": false,
          "reason": "report mutation is not approved by default; workspace reports are local archive artifacts unless explicitly promoted into governed surfaces"
        }
      },
      "doctrine": {
        "path_prefix": "brains/dealerscope-brain/",
        "require_file": true,
        "classification": "verification_only_manual_governed_by_default",
        "execution": {
          "enabled": false,
          "reason": "doctrine remains manual/governed by default; no automation is approved without an explicit narrow contract"
        }
      },
      "policy": {
        "path_prefix": "continuity/",
        "require_file": true,
        "classification": "verification_only_manual_governed_by_default",
        "execution": {
          "enabled": false,
          "reason": "policy remains manual/governed by default unless an exact safe writable subset is explicitly approved"
        }
      }
    },
    "audit": {
      "require_uniform_resolution_metadata": true,
      "required_promoted_fields": [
        "destination",
        "destination_ref",
        "resolution",
        "resolved_at",
        "execution_mode",
        "fulfillment_proof"
      ],
      "required_executed_fields": [
        "execution_mode",
        "fulfillment_proof",
        "pre_mutation_evidence",
        "post_mutation_evidence",
        "target_status",
        "target_path"
      ],
      "failure_states": [
        "failed_precondition",
        "failed_partial_mutation",
        "reverted",
        "recovery_required"
      ],
      "require_recovery_fields_on_failure": true,
      "required_failure_fields": [
        "failure_stage",
        "failure_reason",
        "recovery_status"
      ],
      "required_partial_failure_fields": [
        "partial_mutation_evidence",
        "degraded_subsystem",
        "recovery_action"
      ]
    }
  }
}
