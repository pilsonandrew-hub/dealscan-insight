{
    "title": "ds-hibid-v2 Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "maxPages": {
            "title": "Max pages per search term",
            "type": "integer",
            "default": 20,
            "description": "Maximum GraphQL pages to fetch per search term (50 lots/page)"
        },
        "pageLength": {
            "title": "Lots per page",
            "type": "integer",
            "default": 50,
            "description": "Number of lots per GraphQL request (max 100)"
        },
        "minBid": {
            "title": "Minimum bid ($)",
            "type": "integer",
            "default": 500
        },
        "maxBid": {
            "title": "Maximum bid ($)",
            "type": "integer",
            "default": 75000
        },
        "minYear": {
            "title": "Minimum vehicle year",
            "type": "integer",
            "default": 2000
        },
        "maxMileage": {
            "title": "Maximum mileage",
            "type": "integer",
            "default": 150000
        },
        "targetStates": {
            "title": "Target US states",
            "type": "array",
            "items": { "type": "string" },
            "default": ["AZ","CA","NV","CO","NM","UT","TX","FL","GA","SC","TN","NC","VA","WA","OR","HI","ID","MT","WY","ND","SD","NE","KS","AL","LA","OK"]
        },
        "searchTerms": {
            "title": "Vehicle make search terms",
            "type": "array",
            "items": { "type": "string" },
            "default": ["ford","chevrolet","toyota","honda","dodge","nissan","jeep","gmc","hyundai","kia","subaru","mazda","bmw","mercedes","audi","lexus","cadillac","lincoln","buick","mitsubishi","volkswagen","volvo","tesla","chrysler"]
        },
        "webhookUrl": {
            "title": "Webhook URL",
            "type": "string",
            "default": "https://dealscan-insight-production.up.railway.app/api/ingest/apify"
        },
        "webhookSecret": {
            "title": "Webhook secret",
            "type": "string",
            "isSecret": true
        }
    }
}
